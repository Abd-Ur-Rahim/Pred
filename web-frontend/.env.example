# Environment variables for Keycloak
# Place in web-frontend/.env.local with your actual values

# ============================================
# NextAuth Configuration
# ============================================

# URL where your Next.js app runs
NEXTAUTH_URL=http://localhost:3000

# Secret for encrypting session tokens
# Generate a random string at least 32 characters long
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-32-character-secret-key-here-change-in-production

# ============================================
# Keycloak Configuration
# ============================================

# URL where Keycloak server is running
KEYCLOAK_URL=http://localhost:8080

# Realm where your users live (default is 'master')
# Can create custom realms in Keycloak admin panel
KEYCLOAK_REALM=master

# Client ID created in Keycloak admin console
# Must match exactly (case-sensitive)
KEYCLOAK_CLIENT_ID=web-frontend

# Client secret from Keycloak Credentials tab
# Get this from: Admin Console → Clients → web-frontend → Credentials → Copy secret
KEYCLOAK_CLIENT_SECRET=your-client-secret-from-keycloak

# ============================================
# Optional: Custom Configuration
# ============================================

# Uncomment to use a custom realm (if created in Keycloak)
# KEYCLOAK_REALM=prod-maintenance

# Uncomment to use HTTPS in production
# KEYCLOAK_URL=https://keycloak.yourdomain.com
# NEXTAUTH_URL=https://app.yourdomain.com
